# ── detonate.sg env ──────────────────────────────────────────────
# Copy to .env and fill in. Leave USE_MOCKS=true to run the whole
# flow with fake data before any sponsor key exists.

# Master switch: true = no external calls, orchestrator returns canned evidence.
USE_MOCKS=true

# The mock phishing kit URL the sandbox detonates against (Person B deploys this).
MOCK_KIT_URL=http://localhost:8080

# ── Telegram (Person B) ──
# From @BotFather /newbot. Long-polling, no webhook needed.
TELEGRAM_BOT_TOKEN=

# ── Daytona (Person A) — sandbox isolation ──
DAYTONA_API_KEY=
# Snapshot baked with Playwright+Chromium (see detonation/Dockerfile).
DAYTONA_SNAPSHOT=det-playwright

# ── Oxylabs (Person A) — SG residential proxy ──
OXYLABS_USER=
OXYLABS_PASS=
OXYLABS_HOST=pr.oxylabs.io
OXYLABS_PORT=7777
OXYLABS_COUNTRY=SG
# Non-SG exit for the scanner pass (so the "datacenter view" is foreign even
# when detonating from within Singapore). Drives the cloak contrast.
OXYLABS_SCANNER_COUNTRY=US

# ── ai& Inference (Person C) — verdict LLM (OpenAI-compatible) ──
AIAND_API_KEY=
AIAND_BASE_URL=https://api.aiand.com/v1
AIAND_MODEL=deepseek-ai/deepseek-v4-flash
# Vision-capable ai& model used as the Nosana fallback.
AIAND_VISION_MODEL=moonshotai/kimi-k2.6

# ── Nosana (Person C) — vision model (OpenAI-compatible vLLM endpoint) ──
# Set to the deployed https://<id>.node.k8s.prd.nos.ci/v1 URL.
NOSANA_BASE_URL=
NOSANA_API_KEY=placeholder
NOSANA_MODEL=qwen2.5-vl
# When true (or when NOSANA_BASE_URL is empty), vision falls back to ai&.
NOSANA_FALLBACK=false

# ── Doubleword (Person C) — OCR (OpenAI-compatible), polish tier ──
DOUBLEWORD_API_KEY=
DOUBLEWORD_BASE_URL=https://api.doubleword.ai/v1
DOUBLEWORD_MODEL=DeepSeek-OCR-2
